# ── OpenSpec design docs (local only) ────────────────────────────────────────
openspec/

# ── Claude Code workflow config (local only) ─────────────────────────────────
.claude/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.egg

# ── PyInstaller ───────────────────────────────────────────────────────────────
# Keep electron/scripts/server.spec but ignore other spec files
*.spec
!electron/scripts/server.spec
/tmp/pyinstaller-build/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Frontend build ────────────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ── Backend static (frontend build copied here) ───────────────────────────────
backend/static/

# ── Electron build artifacts ──────────────────────────────────────────────────
electron/dist/
electron/resources/backend/

# ── Database & uploads ────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
uploads/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
